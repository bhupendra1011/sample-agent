# Agora Configuration
# Copy this file to .env and fill in your own values

# Your Agora App ID (get from Agora Console)
VITE_AGORA_APP_ID=""

# Your Agora API Key (get from Agora Console)
VITE_AGORA_API_KEY=""

# Agora Managed Service URL (default value provided)
VITE_AGORA_MANAGED_SERVICE_URL="https://managedservices-preprod.rteappbuilder.com/v1"

# Your Agora Project ID
VITE_AGORA_PROJECT_ID=""

# Whiteboard App Identifier (get from Agora Console > Whiteboard)
VITE_AGORA_WHITEBOARD_APPIDENTIFIER=""

# Whiteboard Region (e.g., "us-sv", "sg", "cn-hz", "in-mum", "eu")
VITE_AGORA_WHITEBOARD_REGION=""
