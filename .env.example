# Agora Configuration
# Copy this file to .env and fill in your own values

# ===========================================
# Google Auth (NextAuth.js)
# ===========================================
# Get Client ID and Secret from Google Cloud Console: APIs & Services → Credentials → OAuth client ID (Web application).
# Redirect URI in Console must be: http://localhost:3000/api/auth/callback/google (and production URL when deployed).
# Generate AUTH_SECRET: e.g. openssl rand -base64 32
AUTH_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Your Agora App ID (get from Agora Console)
NEXT_PUBLIC_AGORA_APP_ID=""

# Agora Managed Service URL (default value provided)
NEXT_PUBLIC_AGORA_MANAGED_SERVICE_URL="https://managedservices-prod.rteappbuilder.com/v1"

# Your Agora Project ID
NEXT_PUBLIC_AGORA_PROJECT_ID=""

# Whiteboard App Identifier (get from Agora Console > Whiteboard)
NEXT_PUBLIC_AGORA_WHITEBOARD_APPIDENTIFIER=""

# Whiteboard Region (e.g., "us-sv", "sg", "cn-hz", "in-mum", "eu")
NEXT_PUBLIC_AGORA_WHITEBOARD_REGION=""

# Server-only: Agora App Certificate (for Conversational AI token generation)
AGORA_APP_CERTIFICATE=""

# Server-only: Agora RESTful API credentials (for Conversational AI API)
AGORA_CUSTOMER_ID=""
AGORA_CUSTOMER_SECRET=""

# Optional: set to 1 or true to log full agent-invite request payload (no masking) for verification
# AGORA_LOG_PAYLOAD_VERBOSE=""

# ===========================================
# AI Agent Configuration (Conversational AI)
# ===========================================
# API keys: use SERVER-ONLY variable names (no NEXT_PUBLIC_ prefix) so the server
# can inject them and the client never sees them. Set the variables below; the
# invite API will use them when the client sends empty key fields.

# --- LLM Configuration ---
# LLM provider: openai, azure, anthropic, cohere, gemini, custom (defaults to openai)
NEXT_PUBLIC_LLM_VENDOR="openai"
NEXT_PUBLIC_LLM_URL="https://api.openai.com/v1/chat/completions"
NEXT_PUBLIC_LLM_MODEL="gpt-4o-mini"
# Server-only (do not use NEXT_PUBLIC_ for API keys)
LLM_API_KEY=""

# --- TTS Configuration ---
# TTS provider: microsoft, elevenlabs, or openai (defaults to microsoft)
NEXT_PUBLIC_TTS_VENDOR="elevenlabs"
# Premade voice "Jessica" (default in app when unset)
NEXT_PUBLIC_ELEVENLABS_VOICE_ID="cgSgspJ2msm6clMCkdW9"
NEXT_PUBLIC_ELEVENLABS_MODEL_ID="eleven_flash_v2_5"
NEXT_PUBLIC_ELEVENLABS_SAMPLE_RATE="24000"
# Server-only TTS API keys (do not use NEXT_PUBLIC_ for API keys)
ELEVENLABS_API_KEY=""
MICROSOFT_TTS_KEY=""
OPENAI_TTS_KEY=""

# --- ASR Configuration ---
# ASR provider: ares (Agora built-in), deepgram, or microsoft (defaults to ares)
NEXT_PUBLIC_ASR_VENDOR="ares"
NEXT_PUBLIC_DEEPGRAM_URL="wss://api.deepgram.com/v1/listen"
NEXT_PUBLIC_DEEPGRAM_MODEL="nova-2"
NEXT_PUBLIC_DEEPGRAM_LANGUAGE="en"
NEXT_PUBLIC_MICROSOFT_ASR_REGION="eastus"
NEXT_PUBLIC_ASR_LANGUAGE="en-US"
# Server-only ASR API keys (do not use NEXT_PUBLIC_ for API keys)
DEEPGRAM_API_KEY=""
MICROSOFT_ASR_KEY=""

# ===========================================
# AI Avatar (Optional) - Default: HeyGen
# ===========================================
# IMPORTANT: Avatar providers have specific requirements:
# - HeyGen requires a STREAMING avatar ID (not a regular avatar ID)
# - To get valid streaming avatar IDs, call: GET https://api.heygen.com/v1/streaming/avatar.list
#   with header: X-Api-Key: <your-heygen-api-key>
# - Your HeyGen account must have Streaming Avatar access (check your plan)

# HeyGen (Beta) - requires 24kHz TTS (e.g. ElevenLabs or OpenAI TTS)
NEXT_PUBLIC_HEYGEN_AVATAR_ID=""
NEXT_PUBLIC_HEYGEN_QUALITY="medium"
# Server-only (do not use NEXT_PUBLIC_ for API keys)
HEYGEN_API_KEY=""

# Akool (Beta) - requires 16kHz TTS (e.g. Microsoft Azure TTS)
# Docs: https://docs.agora.io/en/conversational-ai/models/avatar/akool
NEXT_PUBLIC_AKOOL_AVATAR_ID=""
# Server-only (do not use NEXT_PUBLIC_ for API keys)
AKOOL_API_KEY=""

# Anam - same production endpoint as HeyGen; requires 24kHz TTS (e.g. ElevenLabs or OpenAI TTS)
# Avatar IDs are UUIDs from https://docs.anam.ai/resources/avatar-gallery
NEXT_PUBLIC_ANAM_AVATAR_ID=""
# Server-only (do not use NEXT_PUBLIC_ for API keys)
ANAM_API_KEY=""

# Optional: Vercel Deployment Protection Bypass — add to MCP server headers in settings if needed.
VERCEL_AUTOMATION_BYPASS_SECRET=""
